  "title": "Nshim’umwami wo mw’ijuru",
  "slug": "nshimumwami-wo-mwijuru",
  "uuid": "ff8ffd26-0670-11ea-9a58-deadbe058832",
  "category": "Guhimbaza",
  "url": "https://indirimbo.com/gushimisha/nshimumwami-wo-mwijuru/ff8ffd26-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Nshim’umwami wo mw’ijuru",
        "Ntang’ibyo mushimisha",
        "Nari mboshyw’arambohora",
        "Nari ndway’arankiza",
        "Tumushime tumushime (X3)",
        "Ni we mwam’uhoraho."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Basogokuru kera",
        "bari mu  mubabaro",
        "abagirir’imbabazi",
        "tumuhimbariz’ibyo",
        "na none tumwizigire (X3)",
        "kukw ar’uko yahoze."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Ni data wa twese mwiza",
        "Az’intege nke zacu",
        "nukw’aradukuyakuya",
        "ngw’aturinde satani",
        "duhimbaze imbabazi ze (X3)",
        "zitarangir’iteka."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Yemwe bamarayika beza",
        "nimushim’uwiteka",
        "namwe bera bo mw’ijuru",
        "bavuye mwisi yose",
        "mwese mwishimane natwe (X3)",
        "nyirigir’uhoraho."
      ]
    }
  ]
}