  "title": "Nimuze, dusange Yesu",
  "slug": "nimuze-dusange-yesu",
  "uuid": "ff99b655-0670-11ea-9a58-deadbe058832",
  "category": "Guhimbaza",
  "url": "https://indirimbo.com/gushimisha/nimuze-dusange-yesu/ff99b655-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Nimuze, dusange Yesu : Ni W' udukesh' imitima. Turirimbe, tunezerwe, Kuko tur' intore ze"
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Data yatumy' Umwana we Ngw ‘atuzanir' ubugingo. Ni W' ubw'",
        "uzatuzamura.Atujyane ku Mana."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Abemey' ayo magambo Bayashima mu mitima, Bameny' Imana Rurema Kandi",
        "bavuz' impundu."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Yesu, kubw' ubuntu bwawe, Uzatwijyanir' i Wawe, Ahw a bat owe n'lmana Bicara",
        "bakishima."
      ]
    }
  ]
}