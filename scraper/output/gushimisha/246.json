{
  "number": 246,
  "book": "Gushimisha",
  "title": "I Gologota, ku Giti",
  "slug": "i-gologota-ku-giti",
  "uuid": "ff96dd90-0670-11ea-9a58-deadbe058832",
  "category": "Umusaraba",
  "url": "https://indirimbo.com/gushimisha/i-gologota-ku-giti/ff96dd90-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "I Gologota, ku Giti,",
        "Ni ho Yesu yabambwe;",
        "Yabambiwe kugira",
        "Ngo tubone kudapfa."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Yes’ amaze kunesha,",
        "Avug’ ijwi rirenga,",
        "Abivuga yeruye,",
        "Ati: Birarangiye !"
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Amaze kuvug’ atyo,",
        "Aherakw arunama,",
        "Yunamishwa n’ibyaha",
        "Byanjye nanze kwihana."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "None ansabye imbabazi,",
        "nihane,mukureyo,",
        "mumanure ku giti,",
        "aruhuke umutima."
      ]
    },
    {
      "type": "verse",
      "number": 5,
      "lines": [
        "Aabantu batihana",
        "bongeye kumubamba,",
        "n'umuruho munini,",
        "umubabaza iteka."
      ]
    },
    {
      "type": "verse",
      "number": 6,
      "lines": [
        "twari twararuhijwe,",
        "twiganyira,twihebye,",
        "none turaruhutse:",
        "Yesu ni uburuhukiro"
      ]
    },
    {
      "type": "verse",
      "number": 7,
      "lines": [
        "nuko abishwe n'ibyaha,",
        "ni muhunge,mukire.",
        "muze,mubikurwemo:",
        "Yesu ni uburuhukiro"
      ]
    },
    {
      "type": "verse",
      "number": 8,
      "lines": [
        "Mukiza,ndakwihaye.",
        "ni wowe wantaruye.",
        "uko nzaba ndi kose,",
        "Yesu,nzagusingiza."
      ]
    }
  ]
}