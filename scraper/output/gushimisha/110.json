      "type": "verse",
      "number": 1,
      "lines": [
        "Igituma nkunda Yesu,Nkikumenyeshe none.",
        "N'ukw uwo Mukiza mwiza Yanguz' amaraso ye."
      ]
    },
    {
      "type": "chorus",
      "lines": [
        "Igituma nkunda Yesu Akandutira byose, N'uko yankuyehw ibyaha, Akonyoza, nkera de"
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Igituma nkunda Yesu N' urukundo yankunze, Akankiz' ibyaha byanjye Byajyaga",
        "bintegeka."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Igituma nkunda Yesu N'ukw ar' Umurengezi . Ahor'antabar' iteka Uk' Umwanz'",
        "anyoheje."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Igituma nkunda Yesu N'ukw atazarorera Kumber umukunzi mwiza, Akamber'",
        "umwungeri."
      ]
    }
  ]
