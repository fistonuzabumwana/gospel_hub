{
  "number": 330,
  "book": "Gushimisha",
  "title": "Wowe, Man' ikiranuka",
  "slug": "wowe-man-ikiranuka",
  "uuid": "ff99a682-0670-11ea-9a58-deadbe058832",
  "category": "Guhimbaza",
  "url": "https://indirimbo.com/gushimisha/wowe-man-ikiranuka/ff99a682-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Wowe, Man' ikiranuka, Turashim' izina ryawe Kuk' uduhay' udukiza. Ujy'utuyobor' i Wawe."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Waduhay' Umwami Yesu, Aza kutwigisha neza Ibir' i Wawe mw ijuru. Ngo",
        "tukuyoboke neza."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Wow' udusabir' iteka, Ube mu mitima yacu; Natwe tujye tugukunda, Kuk' ur'",
        "Umuvunyi wacu."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Uhimbazwe, Mwami Yesu : Twibuka k' uzagaruka Kudushaka, twe n'abacu, Ng'",
        "uduh' ubugingo bushya."
      ]
    }
  ]
}