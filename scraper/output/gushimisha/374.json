{
  "number": 374,
  "book": "Gushimisha",
  "title": "Uyu mwana w'uruhinja ni nde",
  "slug": "uyu-mwana-wuruhinja-ni-nde",
  "uuid": "ff9aa545-0670-11ea-9a58-deadbe058832",
  "category": "Urukundo rw'Imana",
  "url": "https://indirimbo.com/gushimisha/uyu-mwana-wuruhinja-ni-nde/ff9aa545-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Uyu mwana w'uruhinja ni nde,",
        "Wabyawe n'umukene?",
        "Dor' aryamye mu kiraro cy'inka",
        "Kukw icumbi ryabuze.",
        "N' Umuremyi w’isi yose;",
        "Ni W' uhindutse muto; N' Uwiteka",
        "Nyirigira Utaremw’udashira."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Uyu ni nde wishwe n'agahinda,",
        "Wuzuy' umubabaro,",
        "Uj' ashak' imbata za Satani,",
        "Byos' abyihanganira ?",
        "Ni We Mana yacu nziza idutunganiriza",
        "lbibanza byo mw ijuru",
        "N'ibyishimo by'iteka."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Uyu ni nd' uv’ amaraso cyane,",
        "Agahemurwa rwose,",
        "Agakubitw' ibipfunsi n'inshyi,",
        "Ntagir' umurengera?",
        "Ni We Man’ ih' imigisha",
        "Abo yicunguriye, Kand' izacir’urubanza",
        "Abayisuzuguye."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Uyu ni nd' ubambwe n'abagome",
        "Hagati y'abambuzi?",
        "Dor’ afit’ amahwa mu ruhanga :",
        "Arashinyagurirwa !",
        "Ni We Mana yimy’ iteka",
        "Mw ijuru ryera rya Se,",
        "Igahimbazwa n'abera",
        "Yacunguj' amaraso."
      ]
    }
  ]
}