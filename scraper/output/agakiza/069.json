  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Igihugu cyiza kiradutegereje mw ijuru,",
        "Kizicarwamo n'abatowe na Yesu.",
        "Kand' iminsi turimo nayo nikw ihita ningoga",
        "Uwihangany' azaragw' icyo gihugu."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Dor' ubwami bw'Imana buregereje!",
        "Dor' ubwami bw'Imana buregereje!",
        "Mutima wanjye ba maso, Utungan' iminsi",
        "yose.",
        "Dor' ubwami bw'Imana buregereje!"
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Twizeye rwose kuzabon' icyo gihug' uko kiri,",
        "Dutegereje gus' uwaducunguye.",
        "Ibimenyetso bitwereka kw agiye kugaruka,",
        "Bitwereka ko wa munsi wegereje."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Kand' ibyanditswe na byo bivuga , ko Yes' aza vuba.",
        "Kand' ubw' azagaragarira mu bicu.",
        "Haleluya, haleluya azaboha wa mugome,",
        "Umwe wagerageje kuturimbura."
      ]
    },
    {
      "type": "verse",
      "number": 5,
      "lines": [
        "Kand' abantu benshi barananiwe kutegereza,",
        "ubakanguze vuba bya bimenyetso.",
        "Kukw ijambo ry'Imana rishaka gusohora vuba.",
        "N'ukuri tubona ko Yes' aza vuba."
      ]
    }
  ]
}