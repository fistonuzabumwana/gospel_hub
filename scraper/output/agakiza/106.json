{
  "number": 106,
  "book": "Agakiza",
  "title": "Abantu bose batuye mw isi",
  "slug": "abantu-bose-batuye-mw-isi",
  "uuid": "ff9eb8bd-0670-11ea-9a58-deadbe058832",
  "category": "Register",
  "url": "https://indirimbo.com/agakiza/abantu-bose-batuye-mw-isi/ff9eb8bd-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Abantu bose batuye mw isi",
        "Ni bo bahawe Noeli.",
        "Ntidushobora kuzibagirwa",
        "Iyo Noeli twahawe."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Noeli nziza! Noeli nziza! Nimu ze twese tuyiririmbe! Niy' itwi buts' agakiza",
        "kacu Noeli nziza ni Yesu."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "N'igitangaza kukw abashumba Batanz' abandi Noeli. Nta cyubahiro bari bafite,",
        "Nyamar' Iman' ikor' ityo."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "N'igitangaza kuk' uwo mwana Yavukiye mu nzu y'inka. Natw' abakene",
        "turashobora Kuririmbira Noeli."
      ]
    },
    {
      "type": "verse",
      "number": 5,
      "lines": [
        "Mur' iryo joro ritey' ukwaryo Ryaririmbwe na maraika Bat': Icyu bahiro n'icy'",
        "lmana Nay' amahor' abe mw isi."
      ]
    },
    {
      "type": "verse",
      "number": 6,
      "lines": [
        "Kand' uwo mwana nubwo yavu tse Si bose bamwakiriye. Nyamara bose",
        "bamwakiriye Babay' abana b'Imana."
      ]
    }
  ]
}