{
  "number": 32,
  "book": "Agakiza",
  "title": "Sioni sanganir' Umukwe",
  "slug": "sioni-sanganir-umukwe",
  "uuid": "ff9cf3bb-0670-11ea-9a58-deadbe058832",
  "category": "Register",
  "url": "https://indirimbo.com/agakiza/sioni-sanganir-umukwe/ff9cf3bb-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Sioni sanganir' Umukwe",
        "Gend' umwerek' umunezero.",
        "Wibonez' imbere y'Umukwe.",
        "Gir' umwe te wo kwitegura."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Nezerwa, nezerwa, Umukw'agushakahw impundu. Nezerwa, nezerwa, Ngwin'",
        "upfukamir' Ihoraho."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Umukiza wacu yavuye",
        "Ku ntebe y'ubwami mw ijuru.",
        "Yagaragaye mu ruhinja.",
        "Rwaryamishijwe rnu muvure."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Yabay' igitambo gikwiye.",
        "Yaba barijw' i Gologota.",
        "Yapfiriye bose bo mw isi.",
        "Duhabw'agakizak'Imana."
      ]
    },
    {
      "type": "verse",
      "number": 5,
      "lines": [
        "Yaneshej' umwanzi Satani,",
        "Ndetse n'urupfu rwarat'sinzwe.",
        "Yaduhishuriy'ubugingo.",
        "Twahawe kuzabahw iteka."
      ]
    },
    {
      "type": "verse",
      "number": 6,
      "lines": [
        "Agenderer' abababaye,",
        "Abah' a mahoro y'ukuri.",
        "Azahora ku ngom' iteka, Kukwar'",
        "Umwam' ukiranuka."
      ]
    }
  ]
}