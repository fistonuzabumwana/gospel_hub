  "url": "https://indirimbo.com/agakiza/birakomeye-gusobanukirwa-ubuntu/ff9d8f5e-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Birakomeye gusobanukirwa",
        "Ubuntu bw'Iman' Ihoraho.",
        "Nari nuzuy' ibyaha byinshi cyane",
        "Ari ko yarambabariye."
      ]
    },
    {
      "type": "chorus",
      "lines": [
        "None nsigaye nz' Imana. Niy' i ndindir' umunani wanjye. Nza wubon' umuns'",
        "umwe, Ubwo Yes' azugaruka."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Birakorameye gusobanukirwa",
        "U bwinshi bw'urukund' agira.",
        "Nizeye gus' ijambo rye rizima",
        "Kandi rya mpay' umunezero."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Birakomeye gusobanukirwa",
        "Iby' imirimo y'Umwuka we.",
        "Kukw ashobora kuirienyesh' umuntu",
        "Kwizer' Urnwami Yesu Kristo."
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "Nta bwo nz' iminsi yanjye nsiga ranye,",
        "Yo kuba mur' iyi si ndimo.",
        "Har' ubwo nkigiriramw' amakuba,",
        "Ndetse n'umubabaro mwinshi."
      ]
    },
    {
      "type": "verse",
      "number": 5,
      "lines": [
        "Urupfu niba ruzansanga mw isi,",
        "Cyangwa se Yes' akagaruka,",
        "Aje guhindur' abamwiringiye.",
        "Azaba ahagaze mu bicu."
      ]
    }
  ]
}