  "title": "Umv' iri jambo n'iryo kwizerwa",
  "slug": "umv-iri-jambo-niryo-kwizerwa",
  "uuid": "ff9ddb20-0670-11ea-9a58-deadbe058832",
  "category": "Register",
  "url": "https://indirimbo.com/agakiza/umv-iri-jambo-niryo-kwizerwa/ff9ddb20-0670-11ea-9a58-deadbe058832",
  "lyrics": [
    {
      "type": "verse",
      "number": 1,
      "lines": [
        "Umv' iri jambo n'iryo kwizerwa",
        "N'iryo kwemerwa n'abantu bose.",
        "Yuko twahaw' Umukiza Yesu.",
        "Yaje gukiza abanyabyaha."
      ]
    },
    {
      "type": "verse",
      "number": 2,
      "lines": [
        "Nar' uwa mbere mu banyabyaha,",
        "Ariko nsigaye nezerewe.",
        "Umukiza wanjye, Yesu Kristo,",
        "Yanyogesheje ya maraso ye."
      ]
    },
    {
      "type": "verse",
      "number": 3,
      "lines": [
        "Yesu Mukiz' ari hamwe natwe,",
        "Akor' imirimo nk'ukw ashaka.",
        "A can’ umuriro we muri twe.",
        "Ni nde wabasha kumuzitira?"
      ]
    },
    {
      "type": "verse",
      "number": 4,
      "lines": [
        "N'ibipfamatwi bibasha kumva,",
        "Ndetse n'ibimuga bikagenda",
        "N'abanyabibembe barakizwa.",
        "Ubutumwa bwe buramamazwa."
      ]
    },
    {
      "type": "verse",
      "number": 5,
      "lines": [
        "Mwami Yesu, duh' Umwuka Wera",
        "Umuduhuhireh' uyu munsi.",
        "Shayur' abarohamye mu byaha,",
        "Ubamurikire bagaruke."
      ]
    },
    {
      "type": "verse",
      "number": 6,
      "lines": [
        "Ugurur' ijur' ugush' imvura,",
        "Ahu magaye nko mu butayu.",
        "Uhahin du¬re kub' ahatoshye",
        "Havuz' impundu z'umunezero."
      ]
    },
    {
      "type": "verse",
      "number": 7,
      "lines": [
        "N'abapagani bakunamire",
        "Bagu pfukamire bakuramye.",
        "Ukwiy' ishimwe ku bantu bose",
        "N'icyubahiro, Haleluya!"
      ]
    }
  ]
}